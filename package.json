{
  "name": "group-leveling",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gitea:up": "docker compose up -d gitea",
    "gitea:down": "docker compose down",
    "gitea:logs": "docker compose logs -f gitea",
    "codex-server": "node scripts/codex-workflow-server.mjs",
    "codex-server:exec": "RUN_CODEX_EXEC=1 node scripts/codex-workflow-server.mjs",
    "self-host": "node scripts/self-host.mjs",
    "invite": "node scripts/invite.mjs",
    "dev:all": "npm run gitea:up && (npm run codex-server:exec & npm run dev)",
    "dev": "next dev -H ${SOLO_LEVELING_BIND_HOST:-0.0.0.0}",
    "smoke:offline-team": "node scripts/offline-team-smoke.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
